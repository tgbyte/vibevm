# Copy to secrets.env (gitignored) and fill in. Injected into the VM only at
# launch time by ./vibe — never written into the image or a snapshot.
# Use a SCOPED / low-privilege key, not your everyday one.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: point Claude at a custom endpoint (e.g. a LiteLLM gateway). ./vibe
# auto-allows this host for direct egress even with the firewall on. Use
# ANTHROPIC_AUTH_TOKEN instead of/alongside the key if the gateway wants a
# Bearer token. Both are forwarded into the VM at launch.
# ANTHROPIC_BASE_URL=https://llm-gateway.example.com
# ANTHROPIC_AUTH_TOKEN=sk-...
