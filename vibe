#!/usr/bin/env bash
# Launch Claude in auto mode (or a shell) inside the vibevm sandbox.
#   ./vibe [PROJECT]        -> claude in ~/workspace[/PROJECT]
#   ./vibe .                -> PROJECT = the mount for $PWD (resolves workspaces.conf aliases)
#   ./vibe claude [PROJECT] -> same, explicit (use if PROJECT clashes with a subcommand)
#   ./vibe shell [PROJECT]  -> login shell in ~/workspace[/PROJECT]
# Args after PROJECT are forwarded to claude / the shell, e.g.:
#   ./vibe . --resume          resume-picker for this project's sessions
#   ./vibe . -c                continue the most recent session
#   ./vibe foo --resume <id>   resume a specific session by id
set -euo pipefail
# Resolve symlinks so $HERE is the repo dir even when run via a PATH symlink
# (e.g. ~/bin/vibe -> .../vibevm/vibe); otherwise secrets.env and the helper
# scripts below wouldn't be found.
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
. "$HERE/config.sh"
VM="$VM_NAME"

ENVFLAGS=()
# Claude keeps its config (~/.claude.json) and state under CLAUDE_CONFIG_DIR.
# Point it at the persisted ~/.claude mount so login + config survive rebuilds
# (otherwise ~/.claude.json lives in HOME, outside the mount, and is lost).
ENVFLAGS+=(--env "CLAUDE_CONFIG_DIR=/home/vibe/.claude")

if [ -f "$HERE/secrets.env" ]; then
  set -a; . "$HERE/secrets.env"; set +a
  # Forward every variable assigned in secrets.env into the VM session.
  while IFS= read -r line; do
    line="${line#"${line%%[![:space:]]*}"}"          # strip leading whitespace
    case "$line" in ''|'#'*) continue ;; esac
    key="${line%%=*}"; key="${key#export }"; key="${key//[[:space:]]/}"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    [ -n "${!key:-}" ] && ENVFLAGS+=(--env "$key=${!key}")
  done < "$HERE/secrets.env"
fi

# Carry the host git identity into the session so the agent can commit in the VM
# (we keep no credentials in the VM — you push from the host). Nothing persisted.
gname="$(git config user.name  2>/dev/null || true)"
gmail="$(git config user.email 2>/dev/null || true)"
if [ -n "$gname" ] && [ -n "$gmail" ]; then
  ENVFLAGS+=(--env "GIT_AUTHOR_NAME=$gname"    --env "GIT_AUTHOR_EMAIL=$gmail" \
             --env "GIT_COMMITTER_NAME=$gname" --env "GIT_COMMITTER_EMAIL=$gmail")
fi

if ! incus info "$VM" >/dev/null 2>&1; then
  echo "VM '$VM' not found. Run ./create-vm.sh first." >&2
  exit 1
fi

# Subcommands that act on the VM itself — handled here so they don't trigger the
# auto-start/-wait below (you don't want `stop` to first boot the VM).
case "${1:-}" in
  stop)
    # Pause the VM.
    exec incus stop "$VM"
    ;;
  restore)
    # Roll back to a snapshot (default: the baseline 'clean'). Stop first if the
    # VM is running — a stateless snapshot can't be restored onto a live VM.
    snap="${2:-clean}"
    if [ "$(incus info "$VM" | awk '/Status/{print $2}')" = RUNNING ]; then
      incus stop "$VM" --timeout 60
    fi
    exec incus snapshot restore "$VM" "$snap"
    ;;
esac

[ "$(incus info "$VM" | awk '/Status/{print $2}')" = RUNNING ] || incus start "$VM"
until incus exec "$VM" -- true 2>/dev/null; do sleep 1; done

# Claude connects to its API endpoint directly (not via the proxy), so a custom
# ANTHROPIC_BASE_URL host must be allowed for direct egress. Register it once.
if [ -n "${ANTHROPIC_BASE_URL:-}" ]; then
  apihost="$(printf '%s' "$ANTHROPIC_BASE_URL" | sed -E 's#^[a-zA-Z]+://([^/:]+).*#\1#')"
  [ -n "$apihost" ] && incus exec "$VM" -- bash -c "install -d /etc/vibe; touch /etc/vibe/api-hosts; grep -qxF '$apihost' /etc/vibe/api-hosts || { echo '$apihost' >> /etc/vibe/api-hosts; /usr/local/sbin/vibe-firewall apply >/dev/null; }"
fi

case "${1:-claude}" in
  statusline)
    # Re-sync the Claude status line from the host into the VM.
    exec "$HERE/sync-statusline.sh"
    ;;
  persist)
    # Back ~/.claude with host ./claude-home so it survives VM rebuilds.
    exec "$HERE/persist-claude.sh"
    ;;
  firewall)
    # Toggle the egress allowlist (root inside the VM; the agent can't).
    exec incus exec "$VM" -- /usr/local/sbin/vibe-firewall "${2:-status}"
    ;;
  config)
    # Re-apply host config to the running VM: workspace mounts + egress allowlist.
    # (The status line is separate — see `vibe statusline`.)
    "$HERE/mount-workspaces.sh"
    [ -f "$HERE/allowlist" ] || cp "$HERE/allowlist.example" "$HERE/allowlist"
    echo "== Updating egress allowlist =="
    incus file push "$HERE/allowlist" "$VM/root/allowlist" --mode 0644
    incus exec "$VM" -- bash /usr/local/bin/harden.sh
    exit 0
    ;;
  -h|--help|help)
    echo "usage: $(basename "$0") [PROJECT | . | claude [PROJECT] | shell [PROJECT] | config | statusline | persist | firewall <on|off|status> | stop | restore [SNAPSHOT]]"
    echo "  PROJECT is a directory under ~/workspace; Claude (or the shell) starts there."
    echo "  '.' resolves \$PWD to its ~/workspace mount (handles workspaces.conf aliases)."
    echo "  config re-applies host config (mounts + allowlist) to the running VM."
    echo "  stop pauses the VM; restore rolls back to a snapshot (default 'clean')."
    echo "  Args after PROJECT pass through to claude / the shell, e.g. ./vibe . --resume."
    exit 0
    ;;
  claude) runmode=claude; [ $# -gt 0 ] && shift ;;   # drop the 'claude' keyword
  shell)  runmode=shell;  [ $# -gt 0 ] && shift ;;   # drop the 'shell' keyword
  *)      runmode=claude ;;                           # ./vibe <PROJECT> [args…]
esac

# The first non-flag token is the PROJECT; everything after it stays in "$@" and
# is forwarded verbatim to claude / the shell (e.g. ./vibe . --resume).
proj=""
if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then proj="$1"; shift; fi

# "vibe ." -> resolve the current host directory to its ~/workspace mount path.
# The mount NAME can differ from basename "$PWD" when workspaces.conf aliases it
# (name=/abs/path), so mirror the mapping rules in mount-workspaces.sh: match $PWD
# against each mounted source (./workspace/* and workspaces.conf), preferring the
# longest match, and append any path below it. Falls back to basename "$PWD".
if [ "$proj" = "." ]; then
  pwd_abs="$(pwd -P)"
  best_name=""; best_src=""
  consider() {   # $1=mount name  $2=host source path
    local n="$1" p="${2/#\~/$HOME}"
    p="$(cd "$p" 2>/dev/null && pwd -P)" || return 0
    if [ "$pwd_abs" = "$p" ] || [[ "$pwd_abs" == "$p"/* ]]; then
      [ ${#p} -gt ${#best_src} ] && { best_src="$p"; best_name="$n"; }
    fi
    return 0
  }
  if [ -d "$HERE/workspace" ]; then
    for d in "$HERE"/workspace/*/; do [ -d "$d" ] && consider "$(basename "$d")" "$d"; done
  fi
  if [ -f "$HERE/workspaces.conf" ]; then
    while IFS= read -r raw; do
      line="${raw%%#*}"; line="${line#"${line%%[![:space:]]*}"}"; line="${line%"${line##*[![:space:]]}"}"
      [ -z "$line" ] && continue
      # Strip the optional marker (see mount-workspaces.sh); a missing path is
      # handled by consider() either way.
      case "$line" in '?'*) line="${line#\?}"; line="${line#"${line%%[![:space:]]*}"}" ;; esac
      if [[ "$line" == *=* ]]; then consider "${line%%=*}" "${line#*=}"
      else consider "$(basename "$line")" "$line"; fi
    done < "$HERE/workspaces.conf"
  fi
  if [ -n "$best_name" ]; then
    rel="${pwd_abs#"$best_src"}"; rel="${rel#/}"
    proj="$best_name${rel:+/$rel}"
  else
    proj="$(basename "$pwd_abs")"
  fi
fi

# Start Claude (default) or a login shell in ~/workspace[/PROJECT]. The project
# and any forwarded args are passed as positional args (not interpolated) so
# names/args with spaces are safe; the inner shell drops $1 (PROJECT) and passes
# the rest ("$@") on to claude / bash.
if [ "$runmode" = shell ]; then
  exec incus exec "$VM" -t --cwd /home/vibe "${ENVFLAGS[@]}" -- runuser -u vibe -- \
    bash -lc 'cd "$HOME/workspace/$1" 2>/dev/null || { echo "no such dir: ~/workspace/$1" >&2; exit 1; }; shift; exec bash -l "$@"' _ "$proj" "$@"
else
  exec incus exec "$VM" -t --cwd /home/vibe "${ENVFLAGS[@]}" -- runuser -u vibe -- \
    bash -lc 'cd "$HOME/workspace/$1" 2>/dev/null || { echo "no such project: ~/workspace/$1 (mounted? try ./vibe config)" >&2; exit 1; }; shift; exec claude --dangerously-skip-permissions "$@"' _ "$proj" "$@"
fi
