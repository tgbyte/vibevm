#!/usr/bin/env bash
# Launch Claude in auto mode (or a shell) inside the vibevm sandbox.
#   ./vibe          -> claude --dangerously-skip-permissions in ~/workspace
#   ./vibe shell    -> plain login shell as the unprivileged vibe user
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
VM=vibevm

ENVFLAGS=()
if [ -f "$HERE/secrets.env" ]; then
  set -a; . "$HERE/secrets.env"; set +a
  [ -n "${ANTHROPIC_API_KEY:-}" ] && ENVFLAGS+=(--env "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
fi

# Carry the host git identity into the session so the agent can commit in the VM
# (we keep no credentials in the VM — you push from the host). Nothing persisted.
gname="$(git config user.name  2>/dev/null || true)"
gmail="$(git config user.email 2>/dev/null || true)"
if [ -n "$gname" ] && [ -n "$gmail" ]; then
  ENVFLAGS+=(--env "GIT_AUTHOR_NAME=$gname"    --env "GIT_AUTHOR_EMAIL=$gmail" \
             --env "GIT_COMMITTER_NAME=$gname" --env "GIT_COMMITTER_EMAIL=$gmail")
fi

if ! incus info "$VM" >/dev/null 2>&1; then
  echo "VM '$VM' not found. Run ./create-vm.sh first." >&2
  exit 1
fi
[ "$(incus info "$VM" | awk '/Status/{print $2}')" = RUNNING ] || incus start "$VM"
until incus exec "$VM" -- true 2>/dev/null; do sleep 1; done

case "${1:-claude}" in
  claude)
    exec incus exec "$VM" --tty --cwd /home/vibe "${ENVFLAGS[@]}" -- \
      runuser -u vibe -- bash -lc 'cd ~/workspace && exec claude --dangerously-skip-permissions'
    ;;
  shell)
    exec incus exec "$VM" --tty --cwd /home/vibe "${ENVFLAGS[@]}" -- \
      runuser -u vibe -- bash -l
    ;;
  firewall)
    # Toggle the egress allowlist (root inside the VM; the agent can't).
    exec incus exec "$VM" -- /usr/local/sbin/vibe-firewall "${2:-status}"
    ;;
  mounts)
    # Sync ~/workspace mounts to match ./workspace/* and ./workspaces.conf.
    exec "$HERE/mount-workspaces.sh"
    ;;
  statusline)
    # Re-sync the Claude status line from the host into the VM.
    exec "$HERE/sync-statusline.sh"
    ;;
  *)
    echo "usage: $(basename "$0") [claude | shell | mounts | statusline | firewall <on|off|status>]" >&2
    exit 1
    ;;
esac
